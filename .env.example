# OpenAI API key for the Realtime API
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
# OpenAI Realtime model name
OPENAI_REALTIME_MODEL=gpt-realtime
# Voice the model speaks with (e.g. alloy, echo, shimmer, marin, cedar)
OPENAI_VOICE=alloy
# Twilio Account SID (starts with AC)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Twilio Auth Token
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Twilio phone number to call FROM (E.164, e.g. +15551234567)
TWILIO_FROM_NUMBER=+15551234567
# Phone number the bot calls (the test line)
TARGET_NUMBER=+18054398008
# Public ngrok host, hostname only, NO https:// prefix (e.g. my-bot.ngrok.app)
PUBLIC_HOST=your-domain.ngrok.app
# Local port uvicorn binds to
PORT=8080
